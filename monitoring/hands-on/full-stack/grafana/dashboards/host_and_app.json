{
  "title": "Host and App Overview",
  "uid": "host-and-app",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["course", "monitoring"],
  "timezone": "browser",
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-main" },
        "query": { "query": "label_values(node_exporter_build_info, instance)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "current": {}
      },
      {
        "name": "code",
        "label": "Status code",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-main" },
        "query": { "query": "label_values(http_requests_total, code)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU Utilization (%) — $instance",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\", instance=\"$instance\"}[5m])) * 100)",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory Available — $instance",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 536870912 },
              { "color": "green", "value": 2147483648 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        {
          "refId": "A",
          "expr": "node_memory_MemAvailable_bytes{instance=\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Network received (bytes/sec) — $instance",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(node_network_receive_bytes_total{device!=\"lo\", instance=\"$instance\"}[5m])",
          "legendFormat": "{{device}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "p95 HTTP latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "mean"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "title": "Request rate by status code",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (code) (rate(http_requests_total{code=~\"$code\"}[5m]))",
          "legendFormat": "{{code}}"
        }
      ]
    }
  ]
}
